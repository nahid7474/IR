12. Quick suspicious findings

$findings = @()

# 🔹 1. Suspicious process command lines
$procCsv = Join-Path $ProcessDir "processes.csv"

if (Test-Path $procCsv) {
    Import-Csv $procCsv |
        Where-Object {
            $_.CommandLine -match '(?i)encodedcommand|-enc|downloadstring|invoke-expression|iex|bypass|hidden|frombase64string|rundll32|regsvr32|mshta|wscript|cscript'
        } |
        ForEach-Object {
            $findings += [PSCustomObject]@{
                Category = "Suspicious process command line"
                Item     = $_.Name
                Detail   = $_.CommandLine
            }
        }
}

# 🔹 2. Suspicious service paths
$svcCsv = Join-Path $ServiceDir "services.csv"

if (Test-Path $svcCsv) {
    Import-Csv $svcCsv |
        Where-Object {
            $_.PathName -match '(?i)\\users\\|\\appdata\\|\\temp\\|\\programdata\\'
        } |
        ForEach-Object {
            $findings += [PSCustomObject]@{
                Category = "Service path in suspicious location"
                Item     = $_.Name
                Detail   = $_.PathName
            }
        }
}

# 🔹 3. Suspicious scheduled tasks
$taskCsv = Join-Path $PersistenceDir "scheduled_tasks.csv"

if (Test-Path $taskCsv) {
    Import-Csv $taskCsv |
        Where-Object {
            $_.Actions -match '(?i)powershell|cmd.exe|wscript|cscript|mshta|rundll32|regsvr32|encodedcommand|-enc|bypass|appdata|temp|programdata'
        } |
        ForEach-Object {
            $findings += [PSCustomObject]@{
                Category = "Suspicious scheduled task action"
                Item     = "$($_.TaskPath)$($_.TaskName)"
                Detail   = $_.Actions
            }
        }
}

# 🔹 4. Suspicious Run keys
$runCsv = Join-Path $PersistenceDir "run_keys.csv"

if (Test-Path $runCsv) {
    Import-Csv $runCsv |
        Where-Object {
            $_.Value -match '(?i)powershell|cmd.exe|wscript|cscript|mshta|rundll32|regsvr32|appdata|temp|programdata'
        } |
        ForEach-Object {
            $findings += [PSCustomObject]@{
                Category = "Suspicious autorun registry value"
                Item     = $_.Name
                Detail   = "$($_.Source) :: $($_.Value)"
            }
        }
}

# 🔹 5. DNS cache analysis

$dnsCsv = Join-Path $NetworkDir "dns_cache.csv"

if (Test-Path $dnsCsv) {
    Import-Csv $dnsCsv |
        Where-Object {
            $_.Name -match '(?i)[a-z0-9]{10,}\.(com|net|xyz|top|ru|cn)' -or
            $_.Name -match '(?i)pastebin|ngrok|duckdns|no-ip|tor2web|bit\.ly|tinyurl'
        } |
        ForEach-Object {
            $findings += [PSCustomObject]@{
                Category = "Suspicious DNS query"
                Item     = $_.Name
                Detail   = "Resolved to: $($_.Data)"
            }
        }
}

# 🔹 Export findings

$findings |
    Export-Csv -Path (Join-Path $FindingDir "quick_findings.csv") -NoTypeInformation -Encoding UTF8
