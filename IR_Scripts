
Simplified Falcon RTR triage collector

param(
    [int]$LookbackHours = 72,
    [string]$OutRoot = "$env:ProgramData\FalconRTR_Triage"
)

$ErrorActionPreference = "Continue"
$ProgressPreference = "SilentlyContinue"

$HostName = $env:COMPUTERNAME
$UtcNow = (Get-Date).ToUniversalTime()
$RunId = "$HostName" + "_" + $UtcNow.ToString("yyyyMMdd_HHmmss_UTC")

$OutDir = Join-Path $OutRoot $RunId
$ZipPath = Join-Path $OutRoot "$RunId.zip"
$StartTime = (Get-Date).AddHours(-$LookbackHours)

$HostDir        = Join-Path $OutDir "01_Host"
$ProcessDir     = Join-Path $OutDir "02_Processes"
$ServiceDir     = Join-Path $OutDir "03_Services"
$PersistenceDir = Join-Path $OutDir "04_Persistence"
$NetworkDir     = Join-Path $OutDir "05_Network"
$EventDir       = Join-Path $OutDir "06_EventSummaries"
$UserDir        = Join-Path $OutDir "07_Users"
$FindingDir     = Join-Path $OutDir "08_Findings"

@(
    $OutDir,
    $HostDir,
    $ProcessDir,
    $ServiceDir,
    $PersistenceDir,
    $NetworkDir,
    $EventDir,
    $UserDir,
    $FindingDir
) | ForEach-Object {
    New-Item -Path $_ -ItemType Directory -Force | Out-Null
}

"Falcon RTR lightweight triage started: $(Get-Date)" |
    Out-File -FilePath (Join-Path $OutDir "collection_log.txt") -Encoding UTF8

"Host: $HostName" |
    Out-File -FilePath (Join-Path $OutDir "collection_log.txt") -Append -Encoding UTF8

"Lookback hours: $LookbackHours" |
