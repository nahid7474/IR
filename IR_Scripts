11. User artefacts

$profiles = Get-CimInstance Win32_UserProfile |
    Where-Object { $_.LocalPath -and (Test-Path $_.LocalPath) -and -not $_.Special }

$psHistoryFiles = foreach ($profile in $profiles) {
    $hist = Join-Path $profile.LocalPath "AppData\Roaming\Microsoft\Windows\PowerShell\PSReadLine\ConsoleHost_history.txt"

    if (Test-Path -LiteralPath $hist) {
        $destName = (($profile.SID) -replace '[\\/:*?"<>|]', '_') + "_ConsoleHost_history.txt"
        Copy-Item -LiteralPath $hist -Destination (Join-Path $UserDir $destName) -Force -ErrorAction SilentlyContinue

        Get-Item -LiteralPath $hist |
            Select-Object FullName, Length, CreationTimeUtc, LastWriteTimeUtc
    }
}

$psHistoryFiles |
    Export-Csv -Path (Join-Path $UserDir "powershell_history_files.csv") -NoTypeInformation -Encoding UTF8

$recentItems = foreach ($profile in $profiles) {
    $recentPath = Join-Path $profile.LocalPath "AppData\Roaming\Microsoft\Windows\Recent"

    if (Test-Path -LiteralPath $recentPath) {
        Get-ChildItem -LiteralPath $recentPath -Force -ErrorAction SilentlyContinue |
            Select-Object @{Name="ProfilePath";Expression={$profile.LocalPath}}, FullName, Name, CreationTimeUtc, LastWriteTimeUtc, Length
    }
}

$recentItems |
    Export-Csv -Path (Join-Path $UserDir "recent_items_metadata.csv") -NoTypeInformation -Encoding UTF8
