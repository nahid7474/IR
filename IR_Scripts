7. Startup folders

$startupFolders = @(
    "$env:ProgramData\Microsoft\Windows\Start Menu\Programs\Startup"
)

Get-CimInstance Win32_UserProfile |
    Where-Object { $_.LocalPath -and (Test-Path $_.LocalPath) -and -not $_.Special } |
    ForEach-Object {
        $startupFolders += Join-Path $_.LocalPath "AppData\Roaming\Microsoft\Windows\Start Menu\Programs\Startup"
    }

$startupFolderItems = foreach ($folder in $startupFolders) {
    if (Test-Path -LiteralPath $folder) {
        Get-ChildItem -LiteralPath $folder -Force -ErrorAction SilentlyContinue |
            Select-Object FullName, Name, Length, CreationTimeUtc, LastWriteTimeUtc
    }
}

$startupFolderItems |
    Export-Csv -Path (Join-Path $PersistenceDir "startup_folder_items.csv") -NoTypeInformation -Encoding UTF8
